{
  "manifest_version": 2,
  "name": "Aria2 Manager",
  "version": "0.1.0",
  "description": "Send matching Firefox downloads to a local aria2 JSON-RPC instance.",
  "permissions": ["downloads", "storage", "notifications", "webRequest", "cookies", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Aria2 Manager",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aria2-manager@example.local",
      "strict_min_version": "109.0"
    }
  }
}
